{
  "manifest_version": 3,
  "name": "CV Customizer Job Capture",
  "version": "0.1.0",
  "description": "Scrape job details from LinkedIn and other career sites, review them, and send them into the CV Customizer desktop workflow or pending queue.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "CV Customizer Job Capture",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "lib/extractor-core.js",
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}

